{
  "name": "@zap-proto/zap",
  "version": "1.0.0",
  "description": "ZAP — Zero-Copy App Proto. Binary RPC with object capabilities, promise pipelining, multi-transport. Browser + Node + Workers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.js"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/protocol.ts src/transport.ts src/rpc.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/protocol.ts src/transport.ts src/rpc.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "zap",
    "rpc",
    "binary-protocol",
    "object-capabilities",
    "promise-pipelining",
    "mcp",
    "ai",
    "agents",
    "hanzo",
    "capnproto",
    "websocket",
    "multi-transport"
  ],
  "author": "Hanzo AI <dev@hanzo.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zap-proto/zap"
  },
  "homepage": "https://hanzo.ai/zap",
  "bugs": {
    "url": "https://github.com/zap-proto/zap/issues"
  },
  "dependencies": {
    "capnp-ts": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "ws": "^8.18.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
